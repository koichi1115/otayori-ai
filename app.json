{
  "expo": {
    "name": "ぷりかん！",
    "slug": "xangi-dev",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "otayori-ai",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.otayori.ai",
      "buildNumber": "44",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.otayori.ai"
    },
    "extra": {
      "claudeApiKey": "${CLAUDE_API_KEY}",
      "claudeModel": "claude-haiku-4-5-20251001",
      "googleOAuthClientId": "539790701575-bhu998if0q5shkbg64c06ukbt4c9m0pk.apps.googleusercontent.com",
      "router": {},
      "eas": {
        "projectId": "fdf46e5c-3570-41f0-98f0-2574854ccdf1"
      }
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-status-bar",
      [
        "expo-camera",
        {
          "cameraPermission": "カメラでプリントをスキャンするために使用します"
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-font"
    ],
    "owner": "saiko1115"
  }
}
